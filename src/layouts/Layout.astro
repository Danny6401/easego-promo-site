---
import { imageAssets } from "../data/assets.js";
import { pageMeta } from "../data/site-content.js";

const {
	title = pageMeta.default.title,
	description = pageMeta.default.description,
	image = imageAssets.logo,
} = Astro.props;

const canonicalUrl = Astro.url.href;
const metaImage = image.startsWith("http") ? image : new URL(image, Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href={imageAssets.logo} />
		<link rel="apple-touch-icon" href={imageAssets.logo} />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#087d8b" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:locale" content="zh_TW" />
		<meta property="og:image" content={metaImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={metaImage} />
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		font-family:
			Inter, "Noto Sans TC", "Microsoft JhengHei", system-ui, -apple-system,
			BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: #fbfaf7;
		color: #202124;
	}

	* {
		box-sizing: border-box;
	}
</style>
