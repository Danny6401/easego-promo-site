---
import Layout from "../layouts/Layout.astro";
import cooperationData from "../data/cooperation-homestays.json";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const cooperationUrl = `${baseUrl}cooperation/`;
const homestayUrl = (slug) => `${baseUrl}cooperation/${slug}/`;
const advantageIconUrl = (icon) => `${baseUrl}advantage-icons/${icon}.png`;
const ctaPanelUrl = `${baseUrl}cta-panel-transparent.png`;
const logoUrl = `${baseUrl}easegoLogo.png`;
const heroMapUrl = `${baseUrl}taiwan-map-hero.png`;
const regions = cooperationData.regions;
const allHomestays = cooperationData.regions.flatMap((region) => region.homestays);
const regionClassNames = {
  north: "north",
  central: "central",
  south: "south",
  east: "east",
  islands: "islands",
  overseas: "overseas",
};

const navItems = [
  { label: "合作旅宿", href: cooperationUrl },
  { label: "合作優勢", href: "#advantages" },
  { label: "成功案例", href: "#cases" },
  { label: "加入我們", href: "#contact" },
];

const stats = [
  { value: `${allHomestays.length}`, suffix: "+", label: "累積合作旅宿", icon: "building" },
  { value: `${regions.length}`, suffix: "+", label: "區域合作據點", icon: "user" },
  { value: "多平台曝光", suffix: "", label: "精準行銷推廣", icon: "megaphone" },
];

const regionBadges = regions.map((region) => ({
  id: region.id,
  label: region.label,
  count: region.homestays.length,
  className: regionClassNames[region.id] ?? region.id,
  image: region.homestays[0]?.coverImage,
}));

const featuredPartnerSlugs = [
  "taitung-cape-morning",
  "jiufen-mist-house",
  "taichung-oldtown-stay",
  "kenting-blue-cabin",
  "taipei-river-view-stay",
  "yilan-rice-field-villa",
  "penghu-coral-bay",
];

const homestaysBySlug = new Map(allHomestays.map((homestay) => [homestay.slug, homestay]));
const partners = featuredPartnerSlugs
  .map((slug) => homestaysBySlug.get(slug))
  .filter(Boolean)
  .map((homestay) => ({
  name: homestay.name,
  location: homestay.area,
  rating: homestay.rating,
  roomCount: homestay.roomCount,
  summary: homestay.summary,
  href: homestayUrl(homestay.slug),
  image: homestay.coverImage,
}));
const showPartnerControls = partners.length > 5;

const advantages = [
  { title: "多平台聯合曝光", description: "整合多元平台資源，擴大品牌能見度，精準觸及目標客群。", icon: "megaphone" },
  { title: "精準客群導流", description: "數據驅動行銷，將對的旅客帶到你的旅宿，提升訂房轉換。", icon: "target" },
  { title: "提升訂房率", description: "優化曝光與轉換流程，有效提升官網與平台訂房量。", icon: "growth" },
  { title: "長期合作共贏", description: "建立穩定合作關係，互相成長，創造長期價值。", icon: "care" },
  { title: "專人行銷支援", description: "專職行銷顧問服務，提供活動規劃與行銷建議。", icon: "headset" },
  { title: "安心透明合作", description: "合作流程透明公開，成效數據清楚可見，安心可靠。", icon: "shield" },
];

const cases = [
  {
    title: "台東．海岬晨光民宿",
    description: "透過聯合行銷推廣，平日訂房率穩定提升。",
    image: homestaysBySlug.get("taitung-cape-morning")?.coverImage,
    metrics: [
      { value: "35%", label: "訂房率成長" },
      { value: "28%", label: "官網轉換成長" },
    ],
  },
  {
    title: "台中．舊城旅舍",
    description: "精準廣告投放，帶來更多高品質訂單。",
    image: homestaysBySlug.get("taichung-oldtown-stay")?.coverImage,
    metrics: [
      { value: "42%", label: "訂房率成長" },
      { value: "33%", label: "營收成長" },
    ],
  },
  {
    title: "墾丁．藍潮小屋",
    description: "暑假檔期訂單爆滿，品牌聲量大幅提升。",
    image: homestaysBySlug.get("kenting-blue-cabin")?.coverImage,
    metrics: [
      { value: "55%", label: "訂房率成長" },
      { value: "41%", label: "社群互動成長" },
    ],
  },
  {
    title: "南投．杉林斜屋",
    description: "鎖定深度旅客，淡旺季表現更趨均衡。",
    image: homestaysBySlug.get("nantou-forest-loft")?.coverImage,
    metrics: [
      { value: "30%", label: "訂房率成長" },
      { value: "25%", label: "回訪率成長" },
    ],
  },
];
---

<Layout
  title="Easego 聯合行銷合作旅宿｜攜手共創・放大價值・一起成長"
  description="Easego 聯合行銷整合合作旅宿、多平台曝光、精準客群導流與專人行銷支援，協助旅宿品牌提升訂房率與長期營運成效。"
>
  <header class="site-header">
    <a class="brand" href="#top" aria-label="回到首頁">
      <img class="brand-logo" src={logoUrl} alt="Easego" />
      <span>Easego 聯合行銷</span>
    </a>
    <nav class="main-nav" aria-label="主要導覽">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </header>

  <main id="top">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Easego 聯合行銷</p>
        <h1><span>Easego</span>聯合行銷合作</h1>
        <p class="hero-slogan">攜手共創・放大價值・一起成長</p>
        <div class="hero-stats" aria-label="合作旅宿統計">
          {stats.map((item) => (
            <div class="hero-stat">
              <span class="stat-icon" aria-hidden="true">
                {
                  item.icon === "building" && (
                    <svg viewBox="0 0 48 48">
                      <path d="M8 42V15l16-7v34" />
                      <path d="M24 42V20l16 6v16" />
                      <path d="M14 19h3M14 25h3M14 31h3M29 28h3M29 34h3" />
                    </svg>
                  )
                }
                {
                  item.icon === "user" && (
                    <svg viewBox="0 0 48 48">
                      <path d="M24 25a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" />
                      <path d="M9 42c1.7-8.5 7.2-13 15-13s13.3 4.5 15 13" />
                    </svg>
                  )
                }
                {
                  item.icon === "megaphone" && (
                    <svg viewBox="0 0 48 48">
                      <path d="M7 28h8l20 8V12L15 20H7v8Z" />
                      <path d="M15 28l4 11h7l-5-9M39 18l4-4M40 24h6M39 30l4 4" />
                    </svg>
                  )
                }
              </span>
              <span class="stat-copy">
                <strong>{item.value}{item.suffix}</strong>
                <span>{item.label}</span>
              </span>
            </div>
          ))}
        </div>
        <div class="hero-actions">
          <a class="button button-primary" href={cooperationUrl}>立即合作</a>
        </div>
      </div>
      <div class="hero-map" aria-label="合作旅宿區域地圖">
        <div class="map-card">
          <img class="map-image" src={heroMapUrl} alt="台灣合作旅宿分布地圖" />
          {regionBadges.map((region) => (
            <a class={`region-badge ${region.className}`} href={`${baseUrl}cooperation/region/${region.id}/`}>
              {region.image && <img class="badge-photo" src={region.image} alt="" loading="lazy" />}
              <span class="badge-count">
                <span>{region.label}</span>
                <strong>{region.count}間</strong>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="partners" class="section section-light">
      <div class="partner-showcase">
        <div class="section-heading partner-heading">
          <h2>精選合作旅宿</h2>
          <p>嚴選優質旅宿，一起創造更多旅程可能。</p>
          <a class="button button-outline" href={cooperationUrl}>查看更多合作旅宿</a>
        </div>
        <div class="partner-track-shell">
          <div class="partner-track" data-partner-track>
            {partners.map((item) => (
              <article class="partner-card">
                <a href={item.href}>
                  <div class="partner-card-image">
                    <img src={item.image} alt={item.name} loading="lazy" />
                    <span class="partner-location">● {item.location}</span>
                  </div>
                  <div class="partner-card-body">
                    <h3>{item.name}</h3>
                    <p>{item.summary}</p>
                    <div class="partner-card-meta">
                      <span>★ {item.rating}</span>
                      <span>{item.roomCount}</span>
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
          {showPartnerControls && (
            <div class="partner-scroll-controls" aria-label="精選合作旅宿滑動控制">
              <button
                class="partner-scroll-button is-hidden"
                type="button"
                data-partner-scroll="prev"
                aria-label="往前看"
                aria-hidden="true"
                disabled
              >
                ‹
              </button>
              <button class="partner-scroll-button" type="button" data-partner-scroll="next" aria-label="往後看">
                ›
              </button>
            </div>
          )}
        </div>
      </div>
      {
        showPartnerControls && (
          <script>
            const partnerTrack = document.querySelector("[data-partner-track]");
            const partnerButtons = document.querySelectorAll("[data-partner-scroll]");
            const previousPartnerButton = document.querySelector('[data-partner-scroll="prev"]');
            const nextPartnerButton = document.querySelector('[data-partner-scroll="next"]');

            const updatePartnerButtons = () => {
              if (!(partnerTrack instanceof HTMLElement)) return;
              if (!(previousPartnerButton instanceof HTMLButtonElement)) return;
              if (!(nextPartnerButton instanceof HTMLButtonElement)) return;

              const edgeTolerance = 16;
              const maxScrollLeft = partnerTrack.scrollWidth - partnerTrack.clientWidth;
              const atStart = partnerTrack.scrollLeft <= edgeTolerance;
              const atEnd = partnerTrack.scrollLeft >= maxScrollLeft - edgeTolerance;

              previousPartnerButton.classList.toggle("is-hidden", atStart);
              previousPartnerButton.disabled = atStart;
              previousPartnerButton.setAttribute("aria-hidden", String(atStart));

              nextPartnerButton.classList.toggle("is-hidden", atEnd);
              nextPartnerButton.disabled = atEnd;
              nextPartnerButton.setAttribute("aria-hidden", String(atEnd));
            };

            partnerButtons.forEach((button) => {
              button.addEventListener("click", () => {
                if (!(partnerTrack instanceof HTMLElement)) return;

                const direction = button.getAttribute("data-partner-scroll") === "prev" ? -1 : 1;
                partnerTrack.scrollBy({
                  left: partnerTrack.clientWidth * 0.85 * direction,
                  behavior: "smooth",
                });
              });
            });

            if (partnerTrack instanceof HTMLElement) {
              requestAnimationFrame(updatePartnerButtons);
              partnerTrack.addEventListener("scroll", updatePartnerButtons, { passive: true });
              window.addEventListener("resize", updatePartnerButtons);
            }
          </script>
        )
      }
    </section>

    <section id="advantages" class="section section-white">
      <div class="advantage-showcase">
        <div class="section-heading advantage-heading">
          <h2>合作優勢</h2>
          <p>我們提供的不只是曝光，更是實際成效。</p>
        </div>
        <div class="advantage-grid">
          {advantages.map((item) => (
            <article class="advantage-card">
              <span class="advantage-icon" aria-hidden="true">
                <img src={advantageIconUrl(item.icon)} alt="" loading="lazy" />
              </span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="cases" class="section section-light">
      <div class="case-showcase">
        <div class="section-heading case-heading">
          <h2>成功案例</h2>
          <p>與我們合作的旅宿，都看見實際成長。</p>
        </div>
        <div>
          <div class="case-grid">
            {cases.map((item) => (
              <article class="case-card">
                <div class="case-card-main">
                  {item.image && <img src={item.image} alt={item.title} loading="lazy" />}
                  <div class="case-card-body">
                    <h3>{item.title}</h3>
                    <p>{item.description}</p>
                  </div>
                </div>
                <div class="case-metrics">
                  {item.metrics.map((metric) => (
                    <div class="case-metric">
                      <strong>↑ {metric.value}</strong>
                      <span>{metric.label}</span>
                    </div>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="contact" class="section section-cta">
      <div class="cta-panel">
        <div class="cta-visual">
          <img class="cta-image" src={ctaPanelUrl} alt="" loading="lazy" />
        </div>
        <div class="cta-copy">
          <h2>一起合作，創造更多旅程價值</h2>
          <p>加入 Easego 聯合行銷合作夥伴，讓我們一起放大品牌影響力、提升訂房成效。</p>
        </div>
        <div class="cta-action">
          <a class="button cta-button" href={cooperationUrl}>立即合作</a>
          <span>或聯繫我們了解更多合作方案</span>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-main">
        <a class="footer-brand" href="#top" aria-label="回到首頁">
          <img src={logoUrl} alt="Easego" />
          <span>
            <strong>Easego 聯合行銷・合作旅宿</strong>
            <small>攜手共創・放大價值・一起成長</small>
          </span>
        </a>

        <nav class="footer-nav" aria-label="頁尾導覽">
          {navItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>

        <div class="footer-social" aria-label="社群連結">
          <a href="#" aria-label="Facebook">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14 8.5h2V5.2c-.35-.05-1.55-.16-2.95-.16-2.92 0-4.92 1.78-4.92 5.05v2.85H5v3.68h3.13V24h3.84v-7.38h3l.48-3.68h-3.48v-2.48c0-1.06.29-1.96 2.03-1.96Z" />
            </svg>
          </a>
          <a href="#" aria-label="Instagram">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.3" cy="6.7" r="1" />
            </svg>
          </a>
          <a href="#" aria-label="LINE">
            <svg viewBox="0 0 24 24" aria-hidden="true" class="line-icon">
              <path d="M12 3.25c-5.25 0-9.5 3.42-9.5 7.64 0 3.78 3.42 6.94 8.03 7.53.31.07.73.22.84.5.1.25.07.64.03.9l-.14.86c-.04.25-.2.98.82.53 1.02-.44 5.5-3.24 7.5-5.55 1.38-1.52 1.92-3.07 1.92-4.77 0-4.22-4.25-7.64-9.5-7.64Zm-4.04 9.81H5.97a.47.47 0 0 1-.47-.47V8.72c0-.26.21-.47.47-.47s.47.21.47.47v3.4h1.52c.26 0 .47.21.47.47s-.21.47-.47.47Zm2.01-.47c0 .26-.21.47-.47.47s-.47-.21-.47-.47V8.72c0-.26.21-.47.47-.47s.47.21.47.47v3.87Zm4.13 0a.47.47 0 0 1-.84.29l-1.87-2.55v2.26c0 .26-.21.47-.47.47s-.47-.21-.47-.47V8.72a.47.47 0 0 1 .84-.28l1.87 2.55V8.72c0-.26.21-.47.47-.47s.47.21.47.47v3.87Zm3.5-2.4c.26 0 .47.21.47.47s-.21.47-.47.47h-1.52v.99h1.52c.26 0 .47.21.47.47s-.21.47-.47.47h-1.99a.47.47 0 0 1-.47-.47V8.72c0-.26.21-.47.47-.47h1.99c.26 0 .47.21.47.47s-.21.47-.47.47h-1.52v1h1.52Z" />
            </svg>
          </a>
        </div>
      </div>

      <p class="footer-copy">© 2026 Easego 聯合行銷 All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 20px clamp(20px, 4vw, 70px);
    background: rgba(251, 250, 247, 0.94);
    border-bottom: 1px solid rgba(24, 59, 55, 0.08);
    backdrop-filter: blur(12px);
  }

  .site-header a {
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-weight: 900;
    color: #113532;
    text-decoration: none;
  }

  .brand-logo {
    display: block;
    width: auto;
    height: 40px;
    object-fit: contain;
  }

  .main-nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 18px;
    font-size: 15px;
    font-weight: 700;
    color: #2b4f49;
  }

  .main-nav a {
    color: inherit;
    text-decoration: none;
    transition: color 180ms ease;
  }

  .main-nav a:hover {
    color: #0f5e58;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(360px, 0.86fr) minmax(520px, 1.14fr);
    align-items: center;
    min-height: calc(100vh - 96px);
    padding: 0px clamp(28px, 6vw, 80px) 70px;
    background:
      radial-gradient(circle at 74% 28%, rgba(74, 181, 210, 0.18), transparent 28%),
      linear-gradient(180deg, #ffffff 0%, #f5fbfc 100%);
  }

  .hero-copy {
    max-width: 600px;
  }

  .eyebrow {
    margin: 0 0 16px;
    color: #0f5e58;
    font-size: 14px;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 18px;
    font-size: clamp(46px, 5.6vw, 82px);
    line-height: 1.02;
    color: #172e2b;
  }

  h1 span {
    display: block;
    color: #087d8b;
  }

  p {
    margin: 0;
    color: #3b514c;
    line-height: 1.75;
    font-size: 18px;
  }

  .hero-slogan {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 4px;
    color: #172e2b;
    font-size: clamp(20px, 2vw, 28px);
    font-weight: 900;
  }

  .hero-slogan::before,
  .hero-slogan::after {
    display: block;
    width: clamp(26px, 4vw, 54px);
    height: 2px;
    background: #0f8792;
    content: "";
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 32px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 24px;
    border-radius: 999px;
    font-weight: 800;
    text-decoration: none;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    background: #0f5e58;
    color: #fff;
  }

  .button-outline {
    min-height: 44px;
    border: 1px solid rgba(15, 94, 88, 0.36);
    background: rgba(255, 255, 255, 0.76);
    color: #0f5e58;
  }

  .hero-stats {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin-top: 38px;
    max-width: 640px;
  }

  .hero-stat {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    padding: 0 24px;
    border-right: 1px solid rgba(15, 94, 88, 0.14);
  }

  .hero-stat:first-child {
    padding-left: 0;
  }

  .hero-stat:last-child {
    padding-right: 0;
    border-right: 0;
  }

  .stat-icon {
    display: grid;
    width: 44px;
    height: 44px;
    flex: 0 0 auto;
    place-items: center;
    color: #087d8b;
  }

  .stat-icon svg {
    display: block;
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 3;
  }

  .stat-copy {
    display: grid;
    gap: 5px;
    min-width: 0;
  }

  .hero-stat strong {
    display: block;
    min-width: 0;
    color: #087d8b;
    font-size: clamp(24px, 2.4vw, 34px);
    font-weight: 900;
    line-height: 1;
    white-space: nowrap;
  }

  .stat-copy span {
    display: block;
    min-width: 0;
    color: #4e6a62;
    font-size: 13px;
    font-weight: 900;
    line-height: 1.35;
    white-space: nowrap;
  }

  .hero-map {
    min-width: 0;
  }

  .map-card {
    position: relative;
    min-height: 560px;
    border-radius: 28px;
    overflow: hidden;
    background: #e5f6ff;
    box-shadow: 0 28px 72px rgba(8, 88, 115, 0.12);
  }

  .map-card::before {
    position: absolute;
    inset: 0;
    z-index: 2;
