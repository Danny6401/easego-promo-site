---
import Layout from "../layouts/Layout.astro";

const navItems = [
	{ label: "最新消息", href: "#news" },
	{ label: "關於我們", href: "#about" },
	{ label: "客房介紹", href: "#rooms" },
	{ label: "訂房資訊", href: "#booking" },
	{ label: "民宿位置", href: "#location" },
];

const slides = [
	{
		title: "醒在海風與晨光之間",
		subtitle: "台東海岸線旁的靜謐民宿，步行 5 分鐘抵達海邊。",
		image:
			"https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1800&q=85",
	},
	{
		title: "把日常留給山海",
		subtitle: "庭院、露台與大片採光，適合慢旅行與家庭小聚。",
		image:
			"https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?auto=format&fit=crop&w=1800&q=85",
	},
	{
		title: "每一晚都安靜好眠",
		subtitle: "精選寢具、獨立衛浴、在地早餐，讓旅程自然放鬆。",
		image:
			"https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=1800&q=85",
	},
];

const rooms = [
	{
		name: "晨曦雙人房",
		price: "平日 NT$3,200 起",
		images: [
			"https://images.unsplash.com/photo-1560185127-6ed189bf02f4?auto=format&fit=crop&w=900&q=80",
			"https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=900&q=80",
			"https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?auto=format&fit=crop&w=900&q=80",
		],
		description:
			"大片窗景迎進晨光與海風，適合雙人慢旅行。房內配置獨立衛浴與陽台，晚上能安靜聽見海浪聲。",
	},
	{
		name: "海風四人房",
		price: "平日 NT$4,800 起",
		images: [
			"https://images.unsplash.com/photo-1566665797739-1674de7a421a?auto=format&fit=crop&w=900&q=80",
			"https://images.unsplash.com/photo-1590490360182-c33d57733427?auto=format&fit=crop&w=900&q=80",
			"https://images.unsplash.com/photo-1611892440504-42a792e24d32?auto=format&fit=crop&w=900&q=80",
		],
		description:
			"保留寬敞活動空間與柔和採光，適合家庭或好友同行。簡單舒適的配置，讓旅途中也能自在休息。",
	},
	{
		name: "星空包棟",
		price: "平日 NT$16,800 起",
		images: [
			"https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&w=900&q=80",
			"https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?auto=format&fit=crop&w=900&q=80",
			"https://images.unsplash.com/photo-1600607687644-c7171b42498b?auto=format&fit=crop&w=900&q=80",
		],
		description:
			"整棟空間完整保留給同行旅伴，可使用客廳、廚房與庭院。適合家族旅行、慶生聚會與小型包場活動。",
	},
];

const news = [
	{
		date: "2026-06-01",
		displayDate: "2026.06.01",
		title: "夏季海岸假期開放預訂",
		description: "連住兩晚加贈在地早餐組，適用 6 月至 8 月平日入住。",
		image:
			"https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=900&q=80",
	},
	{
		date: "2026-05-20",
		displayDate: "2026.05.20",
		title: "包棟旅客可預約庭院晚餐",
		description: "提前 5 日預約即可安排私廚料理與海景露台座位。",
		image:
			"https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=900&q=80",
	},
	{
		date: "2026-05-05",
		displayDate: "2026.05.05",
		title: "新增車站接送服務",
		description: "台東車站至民宿單趟接送，請於訂房時一併告知班次。",
		image:
			"https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?auto=format&fit=crop&w=900&q=80",
	},
];

const bookingNotices = [
	"進房時間：當日下午 15:00 以後。",
	"退房時間：翌日上午 11:00 以前。退房時，務必請交還房門鑰匙。",
	"當天請依約定人數入住，人數或房間數量若有增減請務必事先告知。",
	"入住時請出示您的證件，以便辦理登記，並繳付住宿費用或尾款。",
	"為維護住宿環境，室內及房間內請勿吸煙、酗酒、聚賭，並嚴禁開趴吸毒，不便處請見諒。",
	"請勿攜帶寵物，不便處請見諒。",
	"為維護住宿安寧，請每位房客保持輕聲細語，相互尊重住宿空間上的安寧。",
	"個人貴重物品請自行妥善保管，如有遺失，恕不負責，敬請見諒。",
	"屋內之傢俱、電器、擺設、器具等皆為本民宿財產，物品如有折損或遺失，敬請照價賠償。",
	"請勿任意移動室內擺設，如床舖、液晶電視。",
	"請把民宿當成您自己的家一樣愛護，並期盼您常回來看我們。",
	"若有服務不周之處，請告訴我們，謝謝您的合作，祝旅途平安順心。",
];
---

<Layout>
	<header class="site-header">
		<a class="brand" href="#top" aria-label="回到首頁">
			<span class="brand-mark">海</span>
			<span>海岬晨光民宿</span>
		</a>
		<button class="nav-toggle" type="button" aria-expanded="false" aria-controls="main-nav">
			<span></span>
			<span></span>
			<span></span>
		</button>
		<nav id="main-nav" class="main-nav" aria-label="主要導覽">
			{navItems.map((item) => <a href={item.href}>{item.label}</a>)}
		</nav>
	</header>

	<main id="top">
		<section class="hero" aria-label="民宿形象輪播">
			<div class="hero-slider" data-slider>
				{
					slides.map((slide, index) => (
						<article
							class:list={["hero-slide", { active: index === 0 }]}
							style={`background-image: linear-gradient(90deg, rgba(13, 31, 35, .74), rgba(13, 31, 35, .2)), url('${slide.image}')`}
						>
							<div class="hero-content">
								<p class="eyebrow">Taitung Coast Stay</p>
								<h1>{slide.title}</h1>
								<p>{slide.subtitle}</p>
								<a class="hero-action" href="#booking">查看訂房資訊</a>
							</div>
						</article>
					))
				}
				<div class="slider-controls" aria-label="輪播控制">
					<button type="button" data-prev aria-label="上一張">‹</button>
					<div class="slider-dots">
						{
							slides.map((_, index) => (
								<button
									type="button"
									class:list={{ active: index === 0 }}
									data-dot={index}
									aria-label={`切換到第 ${index + 1} 張`}
								/>
							))
						}
					</div>
					<button type="button" data-next aria-label="下一張">›</button>
				</div>
			</div>
		</section>

		<aside class="sidebox" data-sidebox aria-label="快速訂房資訊">
			<button
				class="sidebox-toggle"
				type="button"
				aria-label="開啟快速訂房"
				aria-expanded="false"
				data-sidebox-toggle
			>
				<span>快速訂房</span>
			</button>
			<div class="sidebox-panel">
				<button class="sidebox-close" type="button" aria-label="關閉快速訂房" data-sidebox-close>
					<span></span>
					<span></span>
				</button>
				<div class="sidebox-section sidebox-reserve">
					<p>快速訂房</p>
					<a class="sidebox-button" href="#booking">Reserve</a>
				</div>
				<div class="sidebox-section">
					<div class="sidebox-icons" aria-label="訂房平台連結">
						<a href="#booking" aria-label="Booking.com">
							<img
								src="https://www.google.com/s2/favicons?sz=64&domain=booking.com"
								alt=""
								loading="lazy"
							/>
						</a>
						<a href="#booking" aria-label="Agoda">
							<img
								src="https://www.google.com/s2/favicons?sz=64&domain=agoda.com"
								alt=""
								loading="lazy"
							/>
						</a>
						<a href="#booking" aria-label="易遊網">
							<img
								src="https://www.google.com/s2/favicons?sz=64&domain=eztravel.com.tw"
								alt=""
								loading="lazy"
							/>
						</a>
					</div>
				</div>
				<div class="sidebox-section">
					<div class="sidebox-icons" aria-label="社群連結">
						<a href="#" aria-label="Facebook">
							<img
								src="https://www.google.com/s2/favicons?sz=64&domain=facebook.com"
								alt=""
								loading="lazy"
							/>
						</a>
						<a href="#" aria-label="Instagram">
							<img
								src="https://www.google.com/s2/favicons?sz=64&domain=instagram.com"
								alt=""
								loading="lazy"
							/>
						</a>
						<a href="#" aria-label="LINE">
							<img
								src="https://www.google.com/s2/favicons?sz=64&domain=line.me"
								alt=""
								loading="lazy"
							/>
						</a>
					</div>
				</div>
			</div>
		</aside>

		<section id="news" class="section section-muted">
			<div class="section-inner">
				<div class="section-heading">
					<p class="eyebrow">News</p>
					<h2>最新消息</h2>
				</div>
				<div class="news-grid">
					{
						news.map((item) => (
							<article>
								<img src={item.image} alt={`${item.title}照片`} loading="lazy" />
								<div>
									<time datetime={item.date}>{item.displayDate}</time>
									<h3>{item.title}</h3>
									<p>{item.description}</p>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section id="about" class="section">
			<div class="split-layout">
				<div class="about-photo" aria-label="民宿公共空間照片"></div>
				<div class="section-copy">
					<p class="eyebrow">About</p>
					<h2>關於我們</h2>
					<p>
						海岬晨光民宿位在台東東海岸安靜聚落，保留木作、庭院與大片窗景，
						讓旅人用舒服的速度靠近山與海。主人長住在地，能協助安排秘境海灘、
						部落餐桌、單車路線與親子友善行程。
					</p>
					<div class="stats">
						<div><strong>5 min</strong><span>步行到海邊</span></div>
						<div><strong>8 間</strong><span>精緻客房</span></div>
						<div><strong>4.9</strong><span>旅客評分</span></div>
					</div>
				</div>
			</div>
		</section>

		<section id="rooms" class="section section-muted">
			<div class="section-inner">
				<div class="section-heading">
					<p class="eyebrow">Rooms</p>
					<h2>客房介紹</h2>
				</div>
				<div class="room-grid">
					{
						rooms.map((room) => (
							<article class="room-card" data-room-card>
								<div class="room-image-slider">
									{room.images.map((image, imageIndex) => (
										<img
											src={image}
											alt={`${room.name}空間照片 ${imageIndex + 1}`}
											loading="lazy"
											class:list={{ active: imageIndex === 0 }}
										/>
									))}
									<div class="room-image-controls">
										<button type="button" data-room-image-prev aria-label="上一張房型照片">
											‹
										</button>
										<button type="button" data-room-image-next aria-label="下一張房型照片">
											›
										</button>
									</div>
									<div class="room-image-dots" aria-label={`${room.name}照片狀態`}>
										{
											room.images.map((_, imageIndex) => (
												<button
													type="button"
													class:list={{ active: imageIndex === 0 }}
													data-room-image-dot={imageIndex}
													aria-label={`切換到第 ${imageIndex + 1} 張房型照片`}
												/>
											))
										}
									</div>
								</div>
								<div>
									<h3>{room.name}</h3>
									<p>{room.price}</p>
									<p class="room-description">{room.description}</p>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section id="booking" class="section">
			<div class="booking-panel">
				<div>
					<p class="eyebrow">Booking</p>
					<h2>訂房資訊</h2>
					<div class="booking-list">
						<div><span>平日</span><strong>週日至週四</strong></div>
						<div><span>假日</span><strong>週五、週六與國定假日</strong></div>
						<div><span>付款</span><strong>轉帳、信用卡、現金</strong></div>
						<div><span>聯絡</span><strong>089-123-456 / Line @capehome</strong></div>
					</div>
				</div>
				<div class="booking-notices-wrap" data-booking-notices>
					<ul class="booking-notices">
						{
							bookingNotices.map((notice, index) => (
								<li
									class={index >= 4 ? "is-collapsed" : ""}
									data-booking-notice-extra={index >= 4 ? "true" : undefined}
								>
									{notice}
								</li>
							))
						}
					</ul>
					{
						bookingNotices.length > 4 && (
							<button
								class="booking-toggle"
								type="button"
								data-booking-toggle
								aria-expanded="false"
								data-expand-label="查看更多"
								data-collapse-label="收合"
							>
								<span>查看更多</span>
							</button>
						)
					}
				</div>
			</div>
		</section>

		<section id="location" class="section section-location">
			<div class="location-content">
				<div>
					<p class="eyebrow">Location</p>
					<h2>民宿位置</h2>
					<p>台東縣成功鎮海岸路 88 號，鄰近三仙台與都歷海灘。</p>
					<p>自行開車可停放於民宿前庭；搭乘大眾運輸可至台東車站轉乘海線客運。</p>
				</div>
				<div class="map-card" aria-label="民宿位置示意地圖">
					<span>台東海岸</span>
					<strong>海岬晨光民宿</strong>
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<span>© 2026 海岬晨光民宿</span>
		<span>台東縣成功鎮海岸路 88 號</span>
	</footer>
</Layout>

<script>
	const slider = document.querySelector("[data-slider]");

	const navToggle = document.querySelector(".nav-toggle");
	const mainNav = document.querySelector("#main-nav");

	navToggle?.addEventListener("click", () => {
		const isOpen = navToggle.getAttribute("aria-expanded") === "true";
		navToggle.setAttribute("aria-expanded", String(!isOpen));
		mainNav?.classList.toggle("open", !isOpen);
	});

	mainNav?.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", () => {
			navToggle?.setAttribute("aria-expanded", "false");
			mainNav.classList.remove("open");
		});
	});

	const sidebox = document.querySelector("[data-sidebox]");
	const sideboxToggle = sidebox?.querySelector("[data-sidebox-toggle]");
	const sideboxClose = sidebox?.querySelector("[data-sidebox-close]");
	const mobileSideboxQuery = window.matchMedia("(max-width: 980px)");

	const setSideboxOpen = (isOpen) => {
		sidebox?.classList.toggle("is-open", isOpen);
		sideboxToggle?.setAttribute("aria-expanded", String(isOpen));
	};

	sideboxToggle?.addEventListener("click", (event) => {
		if (!mobileSideboxQuery.matches) {
			return;
		}

		event.preventDefault();
		event.stopPropagation();
		setSideboxOpen(!sidebox?.classList.contains("is-open"));
	});

	sideboxClose?.addEventListener("click", (event) => {
		event.preventDefault();
		event.stopPropagation();
		setSideboxOpen(false);
		sideboxToggle?.focus();
	});

	document.addEventListener("click", (event) => {
		if (!mobileSideboxQuery.matches || !sidebox?.classList.contains("is-open")) {
			return;
		}

		if (event.target instanceof Node && sidebox.contains(event.target)) {
			return;
		}

		setSideboxOpen(false);
	});

	sidebox?.querySelectorAll('a[href="#"]').forEach((link) => {
		link.addEventListener("click", (event) => {
			event.preventDefault();
			setSideboxOpen(false);
		});
	});

	sidebox?.querySelectorAll('a:not([href="#"])').forEach((link) => {
		link.addEventListener("click", () => {
			setSideboxOpen(false);
		});
	});

	mobileSideboxQuery.addEventListener("change", () => {
		setSideboxOpen(false);
	});

	if (slider) {
		const slides = Array.from(slider.querySelectorAll(".hero-slide"));
		const dots = Array.from(slider.querySelectorAll("[data-dot]"));
		const prev = slider.querySelector("[data-prev]");
		const next = slider.querySelector("[data-next]");
		let current = 0;
		let timer;

		const showSlide = (target) => {
			current = (target + slides.length) % slides.length;
			slides.forEach((slide, index) => slide.classList.toggle("active", index === current));
			dots.forEach((dot, index) => dot.classList.toggle("active", index === current));
		};

		const start = () => {
			timer = window.setInterval(() => showSlide(current + 1), 5200);
		};

		const restart = () => {
			window.clearInterval(timer);
			start();
		};

		prev?.addEventListener("click", () => {
			showSlide(current - 1);
			restart();
		});

		next?.addEventListener("click", () => {
			showSlide(current + 1);
			restart();
		});

		dots.forEach((dot, index) => {
			dot.addEventListener("click", () => {
				showSlide(index);
				restart();
			});
		});

		start();
	}

	document.querySelectorAll("[data-room-card]").forEach((card) => {
		const images = Array.from(card.querySelectorAll(".room-image-slider img"));
		const prev = card.querySelector("[data-room-image-prev]");
		const next = card.querySelector("[data-room-image-next]");
		const dots = Array.from(card.querySelectorAll("[data-room-image-dot]"));
		let current = 0;

		const showImage = (target) => {
			current = (target + images.length) % images.length;
			images.forEach((image, index) => image.classList.toggle("active", index === current));
			dots.forEach((dot, index) => dot.classList.toggle("active", index === current));
		};

		prev?.addEventListener("click", () => showImage(current - 1));
		next?.addEventListener("click", () => showImage(current + 1));
		dots.forEach((dot, index) => {
			dot.addEventListener("click", () => showImage(index));
		});
	});

	document.querySelectorAll("[data-booking-notices]").forEach((group) => {
		const toggle = group.querySelector("[data-booking-toggle]");
		const extraItems = Array.from(group.querySelectorAll("[data-booking-notice-extra]"));

		if (!toggle || extraItems.length === 0) {
			return;
		}

		const expandLabel = toggle.getAttribute("data-expand-label") ?? "展開更多規則";
		const collapseLabel = toggle.getAttribute("data-collapse-label") ?? "收合規則";

		toggle.addEventListener("click", () => {
			const isExpanded = toggle.getAttribute("aria-expanded") === "true";
			const nextExpanded = !isExpanded;
			const label = toggle.querySelector("span");

			extraItems.forEach((item) => {
				item.classList.toggle("is-collapsed", !nextExpanded);
			});
			toggle.setAttribute("aria-expanded", String(nextExpanded));
			if (label) {
				label.textContent = nextExpanded ? collapseLabel : expandLabel;
			}
		});
	});
</script>

<style>
	:global(html) {
		scroll-behavior: smooth;
		scroll-padding-top: 86px;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.site-header {
		position: fixed;
		top: 0;
		left: 0;
