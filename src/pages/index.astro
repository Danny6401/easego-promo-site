---
import Layout from "../layouts/Layout.astro";

const navItems = [
	{ label: "最新消息", href: "#news" },
	{ label: "關於我們", href: "#about" },
	{ label: "客房介紹", href: "#rooms" },
	{ label: "訂房資訊", href: "#booking" },
	{ label: "民宿位置", href: "#location" },
];

const slides = [
	{
		title: "醒在海風與晨光之間",
		subtitle: "台東海岸線旁的靜謐民宿，步行 5 分鐘抵達海邊。",
		image:
			"https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1800&q=85",
	},
	{
		title: "把日常留給山海",
		subtitle: "庭院、露台與大片採光，適合慢旅行與家庭小聚。",
		image:
			"https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?auto=format&fit=crop&w=1800&q=85",
	},
	{
		title: "每一晚都安靜好眠",
		subtitle: "精選寢具、獨立衛浴、在地早餐，讓旅程自然放鬆。",
		image:
			"https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=1800&q=85",
	},
];

const rooms = [
	{
		name: "晨曦雙人房",
		price: "平日 NT$3,200 起",
		image:
			"https://images.unsplash.com/photo-1560185127-6ed189bf02f4?auto=format&fit=crop&w=900&q=80",
		features: ["一大床", "海景陽台", "乾濕分離衛浴"],
	},
	{
		name: "海風四人房",
		price: "平日 NT$4,800 起",
		image:
			"https://images.unsplash.com/photo-1566665797739-1674de7a421a?auto=format&fit=crop&w=900&q=80",
		features: ["兩張雙人床", "家庭客廳", "兒童備品"],
	},
	{
		name: "星空包棟",
		price: "平日 NT$16,800 起",
		image:
			"https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&w=900&q=80",
		features: ["最多 14 人", "獨立廚房", "庭院烤肉區"],
	},
];
---

<Layout>
	<header class="site-header">
		<a class="brand" href="#top" aria-label="回到首頁">
			<span class="brand-mark">海</span>
			<span>海岬晨光民宿</span>
		</a>
		<nav class="main-nav" aria-label="主要導覽">
			{navItems.map((item) => <a href={item.href}>{item.label}</a>)}
		</nav>
	</header>

	<main id="top">
		<section class="hero" aria-label="民宿形象輪播">
			<div class="hero-slider" data-slider>
				{
					slides.map((slide, index) => (
						<article
							class:list={["hero-slide", { active: index === 0 }]}
							style={`background-image: linear-gradient(90deg, rgba(13, 31, 35, .74), rgba(13, 31, 35, .2)), url('${slide.image}')`}
						>
							<div class="hero-content">
								<p class="eyebrow">Taitung Coast Stay</p>
								<h1>{slide.title}</h1>
								<p>{slide.subtitle}</p>
								<a class="hero-action" href="#booking">查看訂房資訊</a>
							</div>
						</article>
					))
				}
				<div class="slider-controls" aria-label="輪播控制">
					<button type="button" data-prev aria-label="上一張">‹</button>
					<div class="slider-dots">
						{
							slides.map((_, index) => (
								<button
									type="button"
									class:list={{ active: index === 0 }}
									data-dot={index}
									aria-label={`切換到第 ${index + 1} 張`}
								/>
							))
						}
					</div>
					<button type="button" data-next aria-label="下一張">›</button>
				</div>
			</div>
		</section>

		<aside class="sidebox" aria-label="快速訂房資訊">
			<p class="sidebox-label">快速訂房</p>
			<strong>今晚仍有空房</strong>
			<span>入住前 7 日預訂享 95 折</span>
			<a href="tel:+88689123456">089-123-456</a>
			<a class="sidebox-button" href="#booking">看房價</a>
		</aside>

		<section id="news" class="section section-muted">
			<div class="section-inner">
				<div class="section-heading">
					<p class="eyebrow">News</p>
					<h2>最新消息</h2>
				</div>
				<div class="news-grid">
					<article>
						<time datetime="2026-06-01">2026.06.01</time>
						<h3>夏季海岸假期開放預訂</h3>
						<p>連住兩晚加贈在地早餐組，適用 6 月至 8 月平日入住。</p>
					</article>
					<article>
						<time datetime="2026-05-20">2026.05.20</time>
						<h3>包棟旅客可預約庭院晚餐</h3>
						<p>提前 5 日預約即可安排私廚料理與海景露台座位。</p>
					</article>
					<article>
						<time datetime="2026-05-05">2026.05.05</time>
						<h3>新增車站接送服務</h3>
						<p>台東車站至民宿單趟接送，請於訂房時一併告知班次。</p>
					</article>
				</div>
			</div>
		</section>

		<section id="about" class="section">
			<div class="split-layout">
				<div class="about-photo" aria-label="民宿公共空間照片"></div>
				<div class="section-copy">
					<p class="eyebrow">About</p>
					<h2>關於我們</h2>
					<p>
						海岬晨光民宿位在台東東海岸安靜聚落，保留木作、庭院與大片窗景，
						讓旅人用舒服的速度靠近山與海。主人長住在地，能協助安排秘境海灘、
						部落餐桌、單車路線與親子友善行程。
					</p>
					<div class="stats">
						<div><strong>5 min</strong><span>步行到海邊</span></div>
						<div><strong>8 間</strong><span>精緻客房</span></div>
						<div><strong>4.9</strong><span>旅客評分</span></div>
					</div>
				</div>
			</div>
		</section>

		<section id="rooms" class="section section-muted">
			<div class="section-inner">
				<div class="section-heading">
					<p class="eyebrow">Rooms</p>
					<h2>客房介紹</h2>
				</div>
				<div class="room-grid">
					{
						rooms.map((room) => (
							<article class="room-card">
								<img src={room.image} alt={`${room.name}空間照片`} loading="lazy" />
								<div>
									<h3>{room.name}</h3>
									<p>{room.price}</p>
									<ul>
										{room.features.map((feature) => <li>{feature}</li>)}
									</ul>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section id="booking" class="section">
			<div class="booking-panel">
				<div>
					<p class="eyebrow">Booking</p>
					<h2>訂房資訊</h2>
					<p>
						入住時間 15:00 後，退房時間 11:00 前。訂房保留需支付房價 30%
						作為訂金，連續假期與包棟方案請來電確認。
					</p>
				</div>
				<div class="booking-list">
					<div><span>平日</span><strong>週日至週四</strong></div>
					<div><span>假日</span><strong>週五、週六與國定假日</strong></div>
					<div><span>付款</span><strong>轉帳、信用卡、現金</strong></div>
					<div><span>聯絡</span><strong>089-123-456 / Line @capehome</strong></div>
				</div>
			</div>
		</section>

		<section id="location" class="section section-location">
			<div class="location-content">
				<div>
					<p class="eyebrow">Location</p>
					<h2>民宿位置</h2>
					<p>台東縣成功鎮海岸路 88 號，鄰近三仙台與都歷海灘。</p>
					<p>自行開車可停放於民宿前庭；搭乘大眾運輸可至台東車站轉乘海線客運。</p>
				</div>
				<div class="map-card" aria-label="民宿位置示意地圖">
					<span>台東海岸</span>
					<strong>海岬晨光民宿</strong>
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<span>© 2026 海岬晨光民宿</span>
		<span>台東縣成功鎮海岸路 88 號</span>
	</footer>
</Layout>

<script>
	const slider = document.querySelector("[data-slider]");

	if (slider) {
		const slides = Array.from(slider.querySelectorAll(".hero-slide"));
		const dots = Array.from(slider.querySelectorAll("[data-dot]"));
		const prev = slider.querySelector("[data-prev]");
		const next = slider.querySelector("[data-next]");
		let current = 0;
		let timer;

		const showSlide = (target) => {
			current = (target + slides.length) % slides.length;
			slides.forEach((slide, index) => slide.classList.toggle("active", index === current));
			dots.forEach((dot, index) => dot.classList.toggle("active", index === current));
		};

		const start = () => {
			timer = window.setInterval(() => showSlide(current + 1), 5200);
		};

		const restart = () => {
			window.clearInterval(timer);
			start();
		};

		prev?.addEventListener("click", () => {
			showSlide(current - 1);
			restart();
		});

		next?.addEventListener("click", () => {
			showSlide(current + 1);
			restart();
		});

		dots.forEach((dot, index) => {
			dot.addEventListener("click", () => {
				showSlide(index);
				restart();
			});
		});

		start();
	}
</script>

<style>
