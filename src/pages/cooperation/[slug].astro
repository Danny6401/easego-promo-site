---
import Layout from "../../layouts/Layout.astro";
import {
	externalIconUrls,
	sitePath,
} from "../../data/assets.js";
import {
	getFeaturedHomestay,
	getHomestayBySlug,
	getHomestayStaticPaths,
} from "../../data/cooperation.js";
import { getHomestayNavItems, pageMeta } from "../../data/site-content.js";

export function getStaticPaths() {
	return getHomestayStaticPaths();
}

const listUrl = sitePath("cooperation/");
const featuredHomestay = getHomestayBySlug(Astro.params.slug) ?? getFeaturedHomestay();

const navItems = getHomestayNavItems(listUrl);

const slides = featuredHomestay.slides;
const rooms = featuredHomestay.rooms;
const news = featuredHomestay.news;
const bookingRows = featuredHomestay.bookingRows;
const bookingNotices = featuredHomestay.bookingNotices;
const homestayMeta = pageMeta.homestay(featuredHomestay);
const fallbackAvatarText = featuredHomestay.name?.trim().charAt(0) ?? "";
const addressMapEmbedUrl = `https://maps.google.com/maps?q=${encodeURIComponent(
	featuredHomestay.address,
)}&output=embed`;
const mapEmbedUrl = featuredHomestay.googleMapEmbedUrl || addressMapEmbedUrl;
const detailImageVars = [
	`--about-photo-fallback: url('${featuredHomestay.detailImages?.aboutFallback}')`,
	`--booking-panel-bg: url('${featuredHomestay.detailImages?.bookingPanel}')`,
	`--map-card-bg: url('${featuredHomestay.detailImages?.mapCard}')`,
].join("; ");
const hasUsableLink = (href) => Boolean(href && href.trim() && href.trim() !== "#");
const links = featuredHomestay.links ?? {};
---

<Layout
	title={homestayMeta.title}
	description={homestayMeta.description}
	image={homestayMeta.image}
>
	<header class="site-header">
		<a class="brand" href="#top" aria-label="回到首頁">
			<span class:list={["brand-mark", { "brand-mark-logo": featuredHomestay.logo }]}>
				{
					featuredHomestay.logo ? (
						<img src={featuredHomestay.logo} alt={`${featuredHomestay.name} logo`} />
					) : (
						fallbackAvatarText
					)
				}
			</span>
			<span>{featuredHomestay.name}</span>
		</a>
		<button class="nav-toggle" type="button" aria-expanded="false" aria-controls="main-nav">
			<span></span>
			<span></span>
			<span></span>
		</button>
		<nav id="main-nav" class="main-nav" aria-label="主要導覽">
			{navItems.map((item) => <a href={item.href}>{item.label}</a>)}
		</nav>
	</header>

	<main id="top" style={detailImageVars}>
		<section class="hero" aria-label="homestay hero slider">
			<div class="hero-slider" data-slider>
				{
					slides.map((slide, index) => (
						<article
							class:list={["hero-slide", { active: index === 0 }]}
							style={`background-image: linear-gradient(90deg, rgba(13, 31, 35, .74), rgba(13, 31, 35, .2)), url('${slide.image}')`}
						>
							<div class="hero-content">
								<p class="eyebrow">{featuredHomestay.englishName}</p>
								<h1>{slide.title}</h1>
								<p>{slide.subtitle}</p>
								<a class="hero-action" href="#booking">查看訂房資訊</a>
							</div>
						</article>
					))
				}
				<div class="slider-controls" aria-label="slider controls">
					<button type="button" data-prev aria-label="previous slide">&lt;</button>
					<div class="slider-dots">
						{slides.map((_, index) => <button type="button" class:list={{ active: index === 0 }} data-dot={index}></button>)}
					</div>
					<button type="button" data-next aria-label="next slide">&gt;</button>
				</div>
			</div>
		</section>

		<aside class="sidebox" data-sidebox aria-label="booking and social links">
			<button
				class="sidebox-toggle"
				type="button"
				aria-label="toggle booking panel"
				aria-expanded="false"
				data-sidebox-toggle
			>
				<span>快速訂房</span>
			</button>
			<div class="sidebox-panel">
				<button class="sidebox-close" type="button" aria-label="close booking panel" data-sidebox-close>
					<span></span>
					<span></span>
				</button>
				<div class="sidebox-section sidebox-reserve">
					<p>快速訂房</p>
					<a class="sidebox-button" href={links.reserve} hidden={!hasUsableLink(links.reserve)}>Reserve</a>
				</div>
				<div class="sidebox-section">
					<div class="sidebox-icons" aria-label="訂房平台連結">
						<a href={links.booking} aria-label="Booking.com" hidden={!hasUsableLink(links.booking)}>
							<img
								src={externalIconUrls.booking}
								alt=""
								loading="lazy"
							/>
						</a>
						<a href={links.agoda} aria-label="Agoda" hidden={!hasUsableLink(links.agoda)}>
							<img
								src={externalIconUrls.agoda}
								alt=""
								loading="lazy"
							/>
						</a>
						<a href={links.eztravel} aria-label="ezTravel" hidden={!hasUsableLink(links.eztravel)}>
							<img
								src={externalIconUrls.eztravel}
								alt=""
								loading="lazy"
							/>
						</a>
						<a href={links.trip} aria-label="Trip.com" hidden={!hasUsableLink(links.trip)}>
							<img
								src={externalIconUrls.trip}
								alt=""
								loading="lazy"
							/>
						</a>
					</div>
				</div>
				<div class="sidebox-section">
					<div class="sidebox-icons" aria-label="social links">
						<a href={links.facebook} aria-label="Facebook" hidden={!hasUsableLink(links.facebook)}>
							<img
								src={externalIconUrls.facebook}
								alt=""
								loading="lazy"
							/>
						</a>
						<a href={links.instagram} aria-label="Instagram" hidden={!hasUsableLink(links.instagram)}>
							<img
								src={externalIconUrls.instagram}
								alt=""
								loading="lazy"
							/>
						</a>
						<a href={links.line} aria-label="LINE" hidden={!hasUsableLink(links.line)}>
							<img
								src={externalIconUrls.line}
								alt=""
								loading="lazy"
							/>
						</a>
					</div>
				</div>
			</div>
		</aside>

		<section id="news" class="section section-muted">
			<div class="section-inner">
				<div class="section-heading">
					<p class="eyebrow">News</p>
					<h2>最新消息</h2>
				</div>
				<div class="news-grid">
					{
						news.map((item) => (
							<article>
								<img src={item.image} alt={`${item.title}照片`} loading="lazy" />
								<div>
									<time datetime={item.date}>{item.displayDate}</time>
									<h3>{item.title}</h3>
									<p>{item.description}</p>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section id="about" class="section">
			<div class="split-layout">
				<div
					class="about-photo"
					aria-label="民宿公共空間照片"
					style={`background-image: linear-gradient(rgba(24, 59, 55, 0.1), rgba(24, 59, 55, 0.1)), url('${featuredHomestay.aboutImage}')`}
				></div>
				<div class="section-copy">
					<p class="eyebrow">About</p>
					<h2>關於{featuredHomestay.name}</h2>
					<p>{featuredHomestay.about}</p>
					<div class="stats">
						{
							featuredHomestay.stats.map((stat) => (
								<div>
									<strong>{stat.value}</strong>
									<span>{stat.label}</span>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<section id="rooms" class="section section-muted">
			<div class="section-inner">
				<div class="section-heading">
					<p class="eyebrow">Rooms</p>
					<h2>客房介紹</h2>
				</div>
				<div class="room-grid">
					{
						rooms.map((room) => (
							<article class="room-card" data-room-card>
								<div class="room-image-slider">
									{room.images.map((image, imageIndex) => (
										<img
											src={image}
											alt={`${room.name}空間照片 ${imageIndex + 1}`}
											loading="lazy"
											class:list={{ active: imageIndex === 0 }}
										/>
									))}
									<div class="room-image-controls">
										<button type="button" data-room-image-prev aria-label="previous room image">
										&lt;
										</button>
										<button type="button" data-room-image-next aria-label="next room image">
										&gt;
										</button>
									</div>
									<div class="room-image-dots" aria-label={`${room.name} images`}>
										{
											room.images.map((_, imageIndex) => (
												<button
													type="button"
													class:list={{ active: imageIndex === 0 }}
													data-room-image-dot={imageIndex}
											aria-label={"room image " + (imageIndex + 1)}
												/>
											))
										}
									</div>
								</div>
								<div>
									<h3>{room.name}</h3>
									<p>{room.price}</p>
									<p class="room-description">{room.description}</p>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section id="booking" class="section">
			<div class="booking-panel">
				<div>
					<p class="eyebrow">Booking</p>
					<h2>訂房資訊</h2>
					<div class="booking-list">
						{
							bookingRows.map((row) => (
								<div>
									<span>{row.label}</span>
									<strong>{row.value}</strong>
								</div>
							))
						}
					</div>
				</div>
				<div class="booking-notices-wrap" data-booking-notices>
					<ul class="booking-notices">
						{
							bookingNotices.map((notice, index) => (
								<li
									class={index >= 4 ? "is-collapsed" : ""}
									data-booking-notice-extra={index >= 4 ? "true" : undefined}
								>
									{notice}
								</li>
							))
						}
					</ul>
					{
						bookingNotices.length > 4 && (
							<button
								class="booking-toggle"
								type="button"
								data-booking-toggle
								aria-expanded="false"
								data-expand-label="查看更多"
								data-collapse-label="收合"
							>
								<span>查看更多</span>
							</button>
						)
					}
				</div>
			</div>
		</section>

		<section id="location" class="section section-location">
			<div class="location-content">
				<div>
					<p class="eyebrow">Location</p>
					<h2>民宿位置</h2>
					<p>{featuredHomestay.location.description}</p>
					<p>{featuredHomestay.location.transport}</p>
				</div>
				<iframe
					class="google-map"
					src={mapEmbedUrl}
					title={`${featuredHomestay.name} Google Map`}
					loading="lazy"
					allowfullscreen
					referrerpolicy="no-referrer-when-downgrade"
				></iframe>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<span>© 2026 {featuredHomestay.name}</span>
		<span>{featuredHomestay.address}</span>
	</footer>
</Layout>

<script>
	const slider = document.querySelector("[data-slider]");

	const navToggle = document.querySelector(".nav-toggle");
	const mainNav = document.querySelector("#main-nav");

	navToggle?.addEventListener("click", () => {
		const isOpen = navToggle.getAttribute("aria-expanded") === "true";
		navToggle.setAttribute("aria-expanded", String(!isOpen));
		mainNav?.classList.toggle("open", !isOpen);
	});

	mainNav?.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", () => {
			navToggle?.setAttribute("aria-expanded", "false");
			mainNav.classList.remove("open");
		});
	});

	const sidebox = document.querySelector("[data-sidebox]");
	const sideboxToggle = sidebox?.querySelector("[data-sidebox-toggle]");
	const sideboxClose = sidebox?.querySelector("[data-sidebox-close]");
	const touchSideboxQuery = window.matchMedia("(hover: none), (pointer: coarse)");

	const setSideboxOpen = (isOpen) => {
		sidebox?.classList.toggle("is-open", isOpen);
		sideboxToggle?.setAttribute("aria-expanded", String(isOpen));
	};

	sideboxToggle?.addEventListener("click", (event) => {
		if (!touchSideboxQuery.matches) {
			return;
		}

		event.preventDefault();
		event.stopPropagation();
		setSideboxOpen(!sidebox?.classList.contains("is-open"));
	});

	sideboxClose?.addEventListener("click", (event) => {
		event.preventDefault();
		event.stopPropagation();
		setSideboxOpen(false);
		sideboxToggle?.focus();
	});

	document.addEventListener("click", (event) => {
		if (!touchSideboxQuery.matches || !sidebox?.classList.contains("is-open")) {
			return;
		}

		if (event.target instanceof Node && sidebox.contains(event.target)) {
			return;
		}

		setSideboxOpen(false);
	});

	sidebox?.querySelectorAll('a[href="#"]').forEach((link) => {
		link.addEventListener("click", (event) => {
			event.preventDefault();
			setSideboxOpen(false);
		});
	});

	sidebox?.querySelectorAll('a:not([href="#"])').forEach((link) => {
		link.addEventListener("click", () => {
			setSideboxOpen(false);
		});
	});

	touchSideboxQuery.addEventListener("change", () => {
		setSideboxOpen(false);
	});

	if (slider) {
		const slides = Array.from(slider.querySelectorAll(".hero-slide"));
		const dots = Array.from(slider.querySelectorAll("[data-dot]"));
		const prev = slider.querySelector("[data-prev]");
		const next = slider.querySelector("[data-next]");
		let current = 0;
		let timer;

		const showSlide = (target) => {
			current = (target + slides.length) % slides.length;
			slides.forEach((slide, index) => slide.classList.toggle("active", index === current));
			dots.forEach((dot, index) => dot.classList.toggle("active", index === current));
		};

		const start = () => {
			timer = window.setInterval(() => showSlide(current + 1), 5200);
		};

		const restart = () => {
			window.clearInterval(timer);
			start();
		};

		prev?.addEventListener("click", () => {
			showSlide(current - 1);
			restart();
		});

		next?.addEventListener("click", () => {
			showSlide(current + 1);
			restart();
		});

		dots.forEach((dot, index) => {
			dot.addEventListener("click", () => {
				showSlide(index);
				restart();
			});
		});

		start();
	}

	document.querySelectorAll("[data-room-card]").forEach((card) => {
		const images = Array.from(card.querySelectorAll(".room-image-slider img"));
		const prev = card.querySelector("[data-room-image-prev]");
		const next = card.querySelector("[data-room-image-next]");
		const dots = Array.from(card.querySelectorAll("[data-room-image-dot]"));
		let current = 0;

		const showImage = (target) => {
			current = (target + images.length) % images.length;
			images.forEach((image, index) => image.classList.toggle("active", index === current));
			dots.forEach((dot, index) => dot.classList.toggle("active", index === current));
		};

		prev?.addEventListener("click", () => showImage(current - 1));
		next?.addEventListener("click", () => showImage(current + 1));
		dots.forEach((dot, index) => {
			dot.addEventListener("click", () => showImage(index));
		});
	});

	document.querySelectorAll("[data-booking-notices]").forEach((group) => {
		const toggle = group.querySelector("[data-booking-toggle]");
		const extraItems = Array.from(group.querySelectorAll("[data-booking-notice-extra]"));

		if (!toggle || extraItems.length === 0) {
			return;
		}

		const expandLabel = toggle.getAttribute("data-expand-label") ?? "展開更多規則";
		const collapseLabel = toggle.getAttribute("data-collapse-label") ?? "收合規則";

		toggle.addEventListener("click", () => {
			const isExpanded = toggle.getAttribute("aria-expanded") === "true";
			const nextExpanded = !isExpanded;
			const label = toggle.querySelector("span");

			extraItems.forEach((item) => {
				item.classList.toggle("is-collapsed", !nextExpanded);
			});
			toggle.setAttribute("aria-expanded", String(nextExpanded));
			if (label) {
				label.textContent = nextExpanded ? collapseLabel : expandLabel;
			}
		});
	});
</script>

<style>
	:global(html) {
		scroll-behavior: smooth;
		scroll-padding-top: 86px;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		z-index: 20;
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		padding: 18px clamp(20px, 5vw, 72px);
		box-sizing: border-box;
		background: rgba(251, 250, 247, 0.92);
		border-bottom: 1px solid rgba(35, 46, 44, 0.1);
		backdrop-filter: blur(18px);
	}

	.brand,
	.main-nav {
		display: flex;
		align-items: center;
	}

	.brand {
		flex: 0 0 auto;
		gap: 10px;
		font-weight: 800;
		color: #193b37;
		text-decoration: none;
	}

	.site-header a {
		text-decoration: none;
	}

	.brand-mark {
		display: grid;
		width: 42px;
		height: 42px;
		place-items: center;
		overflow: hidden;
		border-radius: 50%;
		background: #d86f45;
		color: #fff;
	}

	.brand-mark-logo {
		padding: 4px;
		border: 1px solid rgba(24, 59, 55, 0.14);
		border-radius: 8px;
		background: #fff;
	}

	.brand-mark img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.main-nav {
		flex: 1 1 auto;
		min-width: 0;
		justify-content: flex-end;
		flex-wrap: wrap;
		gap: 10px clamp(12px, 2vw, 28px);
		font-size: 15px;
		font-weight: 700;
		color: #2c4843;
	}

	.main-nav a {
		padding: 8px 0;
	}

	.main-nav a:hover {
		color: #d86f45;
	}

	.nav-toggle {
		display: none;
		position: relative;
		width: 42px;
		height: 42px;
		place-items: center;
		border: 1px solid rgba(24, 59, 55, 0.12);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.78);
		box-shadow: 0 10px 26px rgba(22, 35, 33, 0.1);
		backdrop-filter: blur(12px);
		cursor: pointer;
		transition:
			background 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	.nav-toggle span {
		position: absolute;
		left: 50%;
		display: block;
		width: 19px;
		height: 2px;
		border-radius: 999px;
		background: #183b37;
		transform: translateX(-50%);
		transition:
			top 180ms ease,
			transform 180ms ease,
			opacity 180ms ease;
	}

	.nav-toggle span:nth-child(1) {
		top: 14px;
	}

	.nav-toggle span:nth-child(2) {
		top: 20px;
		width: 14px;
	}

	.nav-toggle span:nth-child(3) {
		top: 26px;
	}

	.nav-toggle:hover,
	.nav-toggle[aria-expanded="true"] {
		background: rgba(255, 255, 255, 0.94);
		border-color: rgba(24, 59, 55, 0.24);
		box-shadow: 0 14px 32px rgba(22, 35, 33, 0.14);
	}

	.nav-toggle[aria-expanded="true"] span:nth-child(1) {
		top: 20px;
		transform: translateX(-50%) rotate(45deg);
	}

	.nav-toggle[aria-expanded="true"] span:nth-child(2) {
		opacity: 0;
		transform: translateX(-50%) scaleX(0);
	}

	.nav-toggle[aria-expanded="true"] span:nth-child(3) {
		top: 20px;
		transform: translateX(-50%) rotate(-45deg);
	}

	.hero {
		height: 100vh;
		min-height: 720px;
		background: #193b37;
		overflow: hidden;
	}

	.hero-slider {
		position: relative;
		height: 100%;
		min-height: inherit;
	}

	.hero-slide {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		padding: 120px clamp(24px, 7vw, 110px) 86px;
		background-position: center;
		background-size: cover;
		opacity: 0;
		transition: opacity 700ms ease;
	}

	.hero-slide.active {
		opacity: 1;
	}

	.hero-content {
		max-width: 720px;
		color: #fff;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #d86f45;
		font-size: 13px;
		font-weight: 900;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.hero-content .eyebrow {
		color: #f5c16b;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		max-width: 780px;
		margin-bottom: 22px;
		font-size: clamp(48px, 6vw, 88px);
		line-height: 1.06;
		letter-spacing: 0;
	}

	h2 {
		margin-bottom: 18px;
		color: #183b37;
		font-size: clamp(32px, 4vw, 52px);
		line-height: 1.12;
		letter-spacing: 0;
	}

	h3 {
		color: #183b37;
		font-size: 22px;
	}

	.hero-content p:not(.eyebrow) {
		max-width: 580px;
		margin-bottom: 30px;
		font-size: 20px;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.9);
	}

	.hero-action,
	.sidebox-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 46px;
		padding: 0 22px;
		border-radius: 4px;
		background: #d86f45;
		color: #fff;
		font-weight: 800;
	}

	.slider-controls {
		position: absolute;
		right: clamp(24px, 7vw, 110px);
